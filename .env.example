# -*- coding: utf-8 -*-
# =============================================================================
# BizCore 環境変数設定テンプレート
# =============================================================================
# このファイルを .env にコピーして、実際の値を設定してください。
# cp .env.example .env
# 既定ではプロジェクトルートに `.env` を配置して実行する前提です。
#
# 2026-03 以降の推奨運用:
# - LLM Provider / Model / Engine の正本は control_plane の LLM Management
# - この .env は Platform と各 app の共通 fallback / 開発補助として利用
# - app は app_config.json の contracts.llm を通して Platform catalog を参照
# =============================================================================

# -----------------------------------------------------------------------------
# Platform Control Plane（推奨）
# -----------------------------------------------------------------------------
# Platform URL（bootstrap / watcher 用）
PLATFORM_URL=http://localhost:8000

# Platform LLM 管理 DB
PLATFORM_DATABASE_URL=sqlite+aiosqlite:///./control_plane/data/control_plane.db
PLATFORM_DB_AUTO_CREATE=true
PLATFORM_DB_ECHO=false

# Provider secret 暗号化キー
# 本番では 32byte 相当のランダム値または十分長いパスフレーズを設定
PLATFORM_SECRET_MASTER_KEY=

# runtime secret cache（通常は既定値のままで可）
PLATFORM_RUNTIME_CACHE_DB=./control_plane/data/control_plane_runtime_cache.db

# -----------------------------------------------------------------------------
# LLM Provider / Model 互換 fallback
# -----------------------------------------------------------------------------
# 注意:
# - 新規運用では Platform 画面で provider / model を設定してください
# - ここにある値は Platform 未設定時または legacy code の互換 fallback です
# - app は raw provider env ではなく contracts.llm を参照します
#
# 明示指定（互換 fallback）: auto / openai / anthropic / google / deepseek / ollama / mock
LLM_PROVIDER=auto

# OpenAI（互換 fallback）
OPENAI_API_KEY=
# legacy default text model
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude（互換 fallback）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini（互換 fallback）
GEMINI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Azure OpenAI（互換 fallback）
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Ollama / LocalAI（互換 fallback）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LocalAI（ローカル）
LOCALAI_BASE_URL=http://localhost:8080
LOCALAI_MODEL=gpt-4

# -----------------------------------------------------------------------------
# データベース（優先順位: Supabase > PostgreSQL > Turso > SQLite）
# -----------------------------------------------------------------------------
# Supabase（推奨）
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# PostgreSQL
DATABASE_URL=

# Turso（SQLite エッジ）
TURSO_URL=libsql://xxx.turso.io
TURSO_AUTH_TOKEN=

# SQLite（ローカル）
# 既定: プロジェクトルート基準の相対パス
SQLITE_PATH=./data/local.db

# -----------------------------------------------------------------------------
# ベクトルデータベース（優先順位: Pinecone > Qdrant > ChromaDB）
# -----------------------------------------------------------------------------
# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=bizcore-index
PINECONE_ENVIRONMENT=us-east-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=bizcore

# ChromaDB（ローカル）
# 既定: プロジェクトルート基準の相対パス
CHROMA_PERSIST_DIR=./data/chroma

# -----------------------------------------------------------------------------
# 長期知識記憶（Knowledge）
# -----------------------------------------------------------------------------
# backend: auto（memvid が利用可能なら memvid、なければ memory）
KNOWLEDGE_BACKEND=auto
# 既定: プロジェクトルート基準で `memory/knowledge`
KNOWLEDGE_STORAGE_PATH=memory/knowledge
# true: 変更を自動保存
KNOWLEDGE_AUTO_PERSIST=true

# -----------------------------------------------------------------------------
# Embedding 互換 fallback
# -----------------------------------------------------------------------------
# 注意:
# - Platform 正本では contracts.llm.defaults.embedding を使用
# - OPENAI_EMBEDDING_MODEL は legacy fallback としてのみ利用
#
# OpenAI Embedding（OPENAI_API_KEY 共用、互換 fallback）
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ローカル Embedding（SentenceTransformer）
USE_LOCAL_EMBEDDING=false
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# アプリケーション設定
# -----------------------------------------------------------------------------
# ログレベル
LOG_LEVEL=INFO

# サーバー設定
HOST=0.0.0.0
PORT=8000

# CORS（カンマ区切り）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# App Auth / Test Bootstrap（共通）
# -----------------------------------------------------------------------------
# 共有テスト用の自動生成:
#   conda run -n bizcore python scripts/bootstrap_test_env.py --env-file .env
#
# Messaging Hub
MESSAGING_HUB_API_KEY_ENV=MESSAGING_HUB_API_KEY
MESSAGING_HUB_API_KEY=

# Code Migration Assistant
CODE_MIGRATION_API_KEY_ENV=CODE_MIGRATION_API_KEY
CODE_MIGRATION_API_KEY=
CODE_MIGRATION_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Design Skills Engine
DESIGN_SKILLS_API_KEY_ENV=DESIGN_SKILLS_API_KEY
DESIGN_SKILLS_API_KEY=

# Legacy Modernization GEO Platform
GEO_PLATFORM_API_KEY_ENV=GEO_PLATFORM_API_KEY
GEO_PLATFORM_API_KEY=
GEO_PLATFORM_HOST=0.0.0.0
GEO_PLATFORM_PORT=8010
GEO_PLATFORM_CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010
GEO_PLATFORM_PUBLIC_BASE_URL=http://localhost:8010
GEO_PLATFORM_DB_PATH=./apps/legacy_modernization_geo_platform/data/geo_platform.db
GEO_PLATFORM_ARTIFACTS_DIR=./apps/legacy_modernization_geo_platform/data/artifacts
GEO_PLATFORM_REPORTS_DIR=./apps/legacy_modernization_geo_platform/data/reports
GEO_PLATFORM_PUBLISHED_DIR=./apps/legacy_modernization_geo_platform/data/published
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# FAQ System / 共通 JWT
JWT_SECRET_KEY=
FAQ_PROXY_AUTH_SHARED_SECRET=

# Decision Governance Engine
POSTGRES_PASSWORD=
SESSION_SECRET=

# -----------------------------------------------------------------------------
# オプション：外部サービス
# -----------------------------------------------------------------------------
# Tavily Search API
TAVILY_API_KEY=

# SerpAPI
SERPAPI_API_KEY=

# GitHub（MCP用）
GITHUB_TOKEN=
