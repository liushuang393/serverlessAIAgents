# =============================================================================
# Code Migration Assistant 設定例
# このファイルを apps/code_migration_assistant/.env にコピーして使用してください
# =============================================================================

# -----------------------------------------------------------------------------
# App API Key / CORS
# -----------------------------------------------------------------------------
CODE_MIGRATION_API_KEY_ENV=CODE_MIGRATION_API_KEY
CODE_MIGRATION_API_KEY=
CODE_MIGRATION_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# -----------------------------------------------------------------------------
# 認証モード
# -----------------------------------------------------------------------------
CODE_MIGRATION_ALLOW_LOCAL_AUTH=true
CODE_MIGRATION_FORCE_AUTH=false
CODE_MIGRATION_ENV=development

# -----------------------------------------------------------------------------
# Platform 主導 LLM 管理
# -----------------------------------------------------------------------------
# この app の text / embedding 正本は app_config.json の contracts.llm です。
# CodeTransformationAgent など一部 agent は coding_openai を override 参照します。
# Provider / model / API Key は apps/platform の LLM Management で管理してください。
# 下記 key は Platform 未設定時の fallback 用です。
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# 互換 fallback（通常は不要）
# LLM_ROLE_CODING_ALIAS=coding_openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# オプション
# -----------------------------------------------------------------------------
# CODE_MIGRATION_REDIS_URL=redis://localhost:6379/0
# LOG_LEVEL=INFO
