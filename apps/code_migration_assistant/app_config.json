{
  "name": "code_migration_assistant",
  "display_name": "コード移行アシスタント",
  "description": "COBOL等レガシーコードからJava等モダン言語へのAI支援移行ツール",
  "business_base": "operations",
  "product_line": "migration",
  "surface_profile": "business",
  "audit_profile": "business",
  "version": "2.0.0",
  "icon": "🔄",
  "ports": {
    "api": 8003,
    "frontend": null,
    "db": null,
    "redis": null
  },
  "entry_points": {
    "api_module": "apps.code_migration_assistant.backend.app:app",
    "health": "/api/health"
  },
  "agents": [
    {
      "name": "LegacyAnalysisAgent",
      "module": "apps.code_migration_assistant.agents.legacy_analysis_agent",
      "capabilities": ["parsing", "analysis", "migration"],
      "business_base": "operations",
      "pattern": "analyzer",
      "agent_type": "reactor"
    },
    {
      "name": "MigrationDesignAgent",
      "module": "apps.code_migration_assistant.agents.migration_design_agent",
      "capabilities": ["migration_design", "architecture"],
      "business_base": "operations",
      "pattern": "pipeline_stage",
      "agent_type": "executor"
    },
    {
      "name": "CodeTransformationAgent",
      "module": "apps.code_migration_assistant.agents.code_transformation_agent",
      "capabilities": ["code_transform", "migration"],
      "business_base": "operations",
      "pattern": "executor",
      "agent_type": "executor"
    },
    {
      "name": "TestSynthesisAgent",
      "module": "apps.code_migration_assistant.agents.test_synthesis_agent",
      "capabilities": ["test_generation"],
      "business_base": "operations",
      "pattern": "executor",
      "agent_type": "executor"
    },
    {
      "name": "DifferentialVerificationAgent",
      "module": "apps.code_migration_assistant.agents.differential_verification_agent",
      "capabilities": ["verification", "review"],
      "business_base": "governance",
      "pattern": "reviewer",
      "agent_type": "reviewer"
    },
    {
      "name": "QualityGateAgent",
      "module": "apps.code_migration_assistant.agents.quality_gate_agent",
      "capabilities": ["quality_gate", "validation", "compliance"],
      "business_base": "governance",
      "pattern": "gatekeeper",
      "agent_type": "gatekeeper"
    },
    {
      "name": "LimitedFixerAgent",
      "module": "apps.code_migration_assistant.agents.limited_fixer_agent",
      "capabilities": ["auto_fix"],
      "business_base": "operations",
      "pattern": "executor",
      "agent_type": "executor"
    },
    {
      "name": "ComplianceReporterAgent",
      "module": "apps.code_migration_assistant.agents.compliance_reporter_agent",
      "capabilities": ["reporting", "audit"],
      "business_base": "governance",
      "pattern": "reporter",
      "agent_type": "reporter"
    },
    {
      "name": "CodeMigrationAgent",
      "module": "apps.code_migration_assistant.agent",
      "capabilities": ["migration", "cobol", "java", "transform"],
      "business_base": "operations",
      "pattern": "coordinator",
      "agent_type": "planner"
    },
    {
      "name": "BusinessSemanticsAgent",
      "module": "apps.code_migration_assistant.agents.business_semantics_agent",
      "capabilities": ["business_analysis", "semantics"],
      "business_base": "operations",
      "pattern": "analyzer",
      "agent_type": "reactor"
    }
  ],
  "services": {
    "engine": {
      "pattern": "pipeline"
    },
    "mcp": {
      "tools": ["cobol_parser", "java_generator", "code_validator"]
    },
    "rag": {
      "enabled": true,
      "pattern": null,
      "chunking": {
        "strategy": "recursive",
        "size": 800,
        "overlap": 120
      },
      "retrieval": {
        "method": "hybrid",
        "reranker": null,
        "top_k": 5,
        "score_threshold": null
      },
      "data_sources": [],
      "indexing_schedule": null
    },
    "vector_db": {
      "provider": "qdrant",
      "url": null,
      "collection": "code_migration_assistant_knowledge"
    }
  },
  "dependencies": {
    "database": null,
    "redis": false,
    "external": ["qdrant", "vector_store"]
  },
  "runtime": {
    "urls": {
      "backend": "http://localhost:8003",
      "frontend": "http://localhost:8003",
      "health": "http://localhost:8003/api/health",
      "database": null
    },
    "database": {
      "kind": null,
      "url": null,
      "host": null,
      "port": null,
      "name": null,
      "user": null,
      "password": null,
      "password_env": null,
      "note": null
    },
    "commands": {
      "backend_dev": "python apps/code_migration_assistant/scripts/dev.py",
      "frontend_dev": null,
      "publish": "docker compose -f docker-compose.yml up -d --build",
      "start": "docker compose -f docker-compose.yml up -d",
      "stop": "docker compose -f docker-compose.yml down"
    }
  },
  "tags": ["cobol", "code-transform", "java", "legacy", "migration", "rag"],
  "contracts": {
    "rag": {
      "enabled": true,
      "pattern": null,
      "provider": "qdrant",
      "collections": ["code_migration_assistant_knowledge"],
      "data_sources": [],
      "chunk_strategy": "recursive",
      "chunk_size": 800,
      "chunk_overlap": 120,
      "retrieval_method": "hybrid",
      "embedding_model": null,
      "rerank_model": null,
      "default_top_k": 5,
      "score_threshold": null,
      "indexing_schedule": null
    },
    "auth": {
      "enabled": true,
      "providers": ["api_key"],
      "allow_anonymous": false,
      "required_scopes": ["api"],
      "session_ttl_minutes": 60
    },
    "llm": {
      "enabled": true,
      "defaults": {
        "text": {
          "provider": "openai",
          "model_id": "platform_text_default",
          "model_type": "text"
        },
        "embedding": {
          "provider": "openai",
          "model_id": "platform_embedding_default",
          "model_type": "embedding"
        }
      },
      "agent_overrides": {
        "CodeTransformationAgent": {
          "text": {
            "provider": "openai",
            "model_id": "coding_openai",
            "model_type": "text"
          }
        },
        "TestSynthesisAgent": {
          "text": {
            "provider": "openai",
            "model_id": "coding_openai",
            "model_type": "text"
          }
        },
        "CodeMigrationAgent": {
          "text": {
            "provider": "openai",
            "model_id": "coding_openai",
            "model_type": "text"
          }
        }
      },
      "allowed_modalities": ["embedding", "text"],
      "extra_model_refs": [
        {
          "provider": "openai",
          "model_id": "coding_openai",
          "model_type": "text"
        }
      ]
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true,
      "allowed_sources": [],
      "default_skills": []
    },
    "release": {
      "strategy": "manual",
      "targets": [],
      "environments": ["dev"],
      "require_approval": true
    }
  },
  "plugin_bindings": [
    {
      "id": "internal.code-migration-runtime-pack",
      "version": "1.0.0",
      "config": {
        "execution_mode": "runtime"
      }
    },
    {
      "id": "official.cobol-migration-pack",
      "version": "1.0.0",
      "config": {
        "target_runtime": "java17"
      }
    },
    {
      "id": "official.test-synthesis-pack",
      "version": "1.0.0",
      "config": {
        "with_e2e": true
      }
    }
  ],
  "blueprint": {
    "engine_pattern": "pipeline",
    "flow_pattern": null,
    "system_prompt": "",
    "llm_provider": null,
    "llm_base_url": null,
    "llm_api_key_env": null,
    "default_model": null,
    "default_skills": [],
    "vector_db_provider": null,
    "vector_db_url": null,
    "vector_db_collection": null,
    "vector_db_api_key_env": null,
    "mcp_servers": ["filesystem", "git"],
    "agents": [],
    "app_template": "ops_automation_runner"
  },
  "visibility": {
    "mode": "private",
    "tenants": []
  },
  "evolution": {
    "enabled": true,
    "strategy_service_url": null,
    "validator_queue": {
      "backend": "redis_stream",
      "redis_url": null,
      "stream_key": "evolution:validate:stream",
      "consumer_group": "evolution-validator-v1",
      "max_retries": 5
    },
    "scope_policy": ["tenant_app", "tenant_product_line", "global_verified"],
    "retrieval": {
      "high_confidence_skip_threshold": 0.82,
      "high_complexity_threshold": 0.7,
      "low_confidence_threshold": 0.55
    },
    "suspicion": {
      "max_age_days": 30,
      "failure_streak_threshold": 2,
      "performance_drop_ratio": 0.2
    }
  }
}
