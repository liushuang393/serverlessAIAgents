# ==============================================================================
# Decision Governance Engine - 環境変数
# ==============================================================================
# 使用方法:
#   1. このファイルを .env にコピー: cp .env.example .env
#      （既定配置: apps/decision_governance_engine/.env）
#   2. ポート自動設定（推奨）: python -m agentflow.tools.port_manager decision_governance_engine apps/decision_governance_engine
#   3. docker-compose up -d
#
# 注意: .env は Git にコミットしない
# ==============================================================================

# ------------------------------------------------------------------------------
# 環境・ホスト設定
# ------------------------------------------------------------------------------
APP_ENV=development
# 開発: localhost / Docker内: host.docker.internal / 本番: 実際の IP
HOST=localhost

# ------------------------------------------------------------------------------
# ポート設定（衝突時は port_manager で自動変更可能）
# ------------------------------------------------------------------------------
DB_PORT=5432
REDIS_PORT=6379
# API_PORT: バックエンドのホスト側ポート（自動切替）
#   開発環境: 8001 (docker-compose.dev.yml 使用時)
#   本番環境: 8000 (デフォルト)
#   ※ 容器内ポートは常に 8000（統一）。ホスト側マッピングのみ変わる。
API_PORT=8001
FRONTEND_PORT=80
FRONTEND_DEV_PORT=5174

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=dge
POSTGRES_PASSWORD=
POSTGRES_DB=decision_governance

# ------------------------------------------------------------------------------
# データベース接続 URL（通常は自動生成されるため設定不要）
# ------------------------------------------------------------------------------
# ローカル開発（Docker外）:
# DATABASE_URL=postgresql+asyncpg://dge:dge_password@localhost:5432/decision_governance
# REDIS_URL=redis://localhost:6379/0
#
# Docker Compose 内（自動設定）:
# DATABASE_URL=postgresql+asyncpg://dge:dge_password@postgres-main:5432/decision_governance
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# アプリケーション設定
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_RAG=true
ENABLE_DECISION_HISTORY=true
MAX_REVISIONS=2

# ------------------------------------------------------------------------------
# フロントエンド設定
# ------------------------------------------------------------------------------
# 既定: http://localhost:8001（HOST/API_PORT の既定値を使用）
VITE_API_URL=http://${HOST}:${API_PORT}
VITE_DEBUG_MODE=false

# ------------------------------------------------------------------------------
# LLM Gateway 設定（LiteLLM 内蔵、ENV 優先）
# ------------------------------------------------------------------------------
# 正本: .agentflow/llm_gateway.yaml
# 必要に応じて設定ファイルパスを上書き
# LLM_GATEWAY_CONFIG_PATH=.agentflow/llm_gateway.yaml

# Provider API keys（いずれか1つ以上）
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# role -> model_alias 上書き（任意）
# LLM_ROLE_REASONING_ALIAS=reasoning_claude
# LLM_ROLE_CODING_ALIAS=coding_openai
# LLM_ROLE_CHEAP_ALIAS=cheap_gemini
# LLM_ROLE_LOCAL_ALIAS=local_qwen2

# ------------------------------------------------------------------------------
# セキュリティ（本番環境で設定）
# ------------------------------------------------------------------------------
# 共有テスト用は自動生成可能:
# conda run -n agentflow python scripts/bootstrap_test_env.py --env-file .env
SESSION_SECRET=
# CORS_ORIGINS=https://your-domain.com

# ------------------------------------------------------------------------------
# 外部サービス（オプション）
# ------------------------------------------------------------------------------
# SENTRY_DSN=

