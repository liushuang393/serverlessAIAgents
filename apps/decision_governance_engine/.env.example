# ==============================================================================
# Decision Governance Engine - 環境変数
# ==============================================================================
# 使用方法:
#   1. このファイルを .env にコピー: cp .env.example .env
#      （既定配置: apps/decision_governance_engine/.env）
#   2. ポート自動設定（推奨）: curl -X POST http://localhost:8000/api/studios/framework/apps/ports/rebalance -H "Content-Type: application/json" -d '{"dry_run": false}'
#   3. docker-compose up -d
#
# 注意: .env は Git にコミットしない
# ==============================================================================

# ------------------------------------------------------------------------------
# 環境・ホスト設定
# ------------------------------------------------------------------------------
APP_ENV=development
# host / port の既定値は app_config.json と docker-compose*.yml のみで管理する
# .env には通常定義しないこと

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=dge
POSTGRES_PASSWORD=
POSTGRES_DB=decision_governance

# ------------------------------------------------------------------------------
# データベース接続 URL（通常は自動生成されるため設定不要）
# ------------------------------------------------------------------------------
# ローカル開発（Docker外）:
# DATABASE_URL=postgresql+asyncpg://dge:dge_password@localhost:5432/decision_governance
# REDIS_URL=redis://localhost:6379/0
#
# Docker Compose 内（自動設定）:
# DATABASE_URL=postgresql+asyncpg://dge:dge_password@postgres-main:5432/decision_governance
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# アプリケーション設定
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_RAG=true
ENABLE_DECISION_HISTORY=true
MAX_REVISIONS=2

# ------------------------------------------------------------------------------
# フロントエンド設定
# ------------------------------------------------------------------------------
# 本番で別オリジン API を使う場合のみ明示 override
# VITE_API_URL=https://api.example.com
VITE_DEBUG_MODE=false

# ------------------------------------------------------------------------------
# Platform 主導 LLM 管理
# ------------------------------------------------------------------------------
# Decision Governance Engine は contracts.llm で Platform catalog の text / embedding を参照します。
# Provider / model / API Key の正本は control_plane の LLM Management です。
# 下記 key は Platform 未設定時または legacy code の fallback 用です。
# 必要に応じて設定ファイルパスを上書き
# LLM_GATEWAY_CONFIG_PATH=.bizcore/llm_gateway.yaml

# Provider API keys（fallback 用）
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# role -> model_alias 上書き（互換 fallback。通常は不要）
# LLM_ROLE_REASONING_ALIAS=reasoning_claude
# LLM_ROLE_CODING_ALIAS=coding_openai
# LLM_ROLE_CHEAP_ALIAS=cheap_gemini
# LLM_ROLE_LOCAL_ALIAS=local_qwen2

# ------------------------------------------------------------------------------
# セキュリティ（本番環境で設定）
# ------------------------------------------------------------------------------
# 共有テスト用は自動生成可能:
# conda run -n bizcore python scripts/bootstrap_test_env.py --env-file .env
SESSION_SECRET=
# CORS_ORIGINS=https://your-domain.com

# ------------------------------------------------------------------------------
# 外部サービス（オプション）
# ------------------------------------------------------------------------------
# SENTRY_DSN=
