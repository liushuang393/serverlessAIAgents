{
  "name": "design_skills_engine",
  "display_name": "デザインスキルエンジン",
  "description": "プラグイン/他Appから再利用される共通デザイン生成サービス。自然言語ブリーフからComfyUI経由で統一スタイルの画像セットを生成",
  "business_base": "media",
  "product_line": "framework",
  "surface_profile": "developer",
  "audit_profile": "developer",
  "version": "1.0.0",
  "icon": "🎨",
  "ports": {
    "api": 8006,
    "frontend": null,
    "db": null,
    "redis": null
  },
  "entry_points": {
    "api_module": "apps.design_skills_engine.main:app",
    "health": "/api/health"
  },
  "agents": [
    {
      "name": "IntentAnalyzerAgent",
      "module": "kernel.skills.builtin.design_skills.agents.intent_analyzer_agent",
      "capabilities": [
        "intent_analysis",
        "design_brief"
      ],
      "business_base": "media",
      "pattern": "analyzer",
      "agent_type": "reactor"
    },
    {
      "name": "PromptPlannerAgent",
      "module": "kernel.skills.builtin.design_skills.agents.prompt_planner_agent",
      "capabilities": [
        "prompt_planning",
        "style_generation"
      ],
      "business_base": "media",
      "pattern": "pipeline_stage",
      "agent_type": "executor"
    },
    {
      "name": "WorkflowExecutorAgent",
      "module": "kernel.skills.builtin.design_skills.agents.workflow_executor_agent",
      "capabilities": [
        "image_generation",
        "comfyui",
        "openai_images"
      ],
      "business_base": "media",
      "pattern": "executor",
      "agent_type": "executor"
    }
  ],
  "services": {
    "comfyui": {
      "default_url": "http://localhost:8188"
    },
    "pipeline": {
      "engine": "DesignSkillsEngine"
    }
  },
  "dependencies": {
    "database": null,
    "redis": false,
    "external": [
      "comfyui"
    ]
  },
  "runtime": {
    "urls": {
      "backend": "http://localhost:8006",
      "frontend": null,
      "health": "http://localhost:8006/api/health",
      "database": null
    },
    "database": {
      "kind": null,
      "url": null,
      "host": null,
      "port": null,
      "name": null,
      "user": null,
      "password": null,
      "password_env": null,
      "note": null
    },
    "commands": {
      "backend_dev": "python apps/design_skills_engine/scripts/dev.py",
      "frontend_dev": null,
      "publish": "docker compose -f docker-compose.yml -f docker-compose.cpu.yml up -d --build",
      "start": "docker compose -f docker-compose.yml -f docker-compose.cpu.yml up -d",
      "stop": "docker compose -f docker-compose.yml -f docker-compose.cpu.yml down"
    }
  },
  "tags": [
    "design",
    "image-generation",
    "comfyui",
    "pipeline",
    "skill",
    "shared-service",
    "plugin-runtime"
  ],
  "contracts": {
    "auth": {
      "enabled": true,
      "providers": [
        "api_key"
      ],
      "allow_anonymous": false,
      "required_scopes": [
        "api"
      ],
      "session_ttl_minutes": 60
    },
    "llm": {
      "enabled": true,
      "defaults": {
        "text": {
          "provider": "openai",
          "model_id": "platform_text_default",
          "model_type": "text"
        },
        "image": {
          "provider": "openai",
          "model_id": "platform_image_default",
          "model_type": "image"
        }
      },
      "agent_overrides": {},
      "allowed_modalities": [
        "image",
        "text"
      ],
      "extra_model_refs": []
    },
    "rag": {
      "enabled": false,
      "pattern": null,
      "provider": null,
      "collections": [],
      "data_sources": [],
      "chunk_strategy": "recursive",
      "chunk_size": 800,
      "chunk_overlap": 120,
      "retrieval_method": "hybrid",
      "embedding_model": null,
      "rerank_model": null,
      "default_top_k": 5,
      "score_threshold": null,
      "indexing_schedule": null
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true,
      "allowed_sources": [],
      "default_skills": []
    },
    "release": {
      "strategy": "manual",
      "targets": [],
      "environments": [
        "dev"
      ],
      "require_approval": true
    }
  },
  "plugin_bindings": [],
  "blueprint": {
    "engine_pattern": "pipeline",
    "flow_pattern": null,
    "system_prompt": "",
    "llm_provider": null,
    "llm_base_url": null,
    "llm_api_key_env": null,
    "default_model": null,
    "default_skills": [],
    "vector_db_provider": null,
    "vector_db_url": null,
    "vector_db_collection": null,
    "vector_db_api_key_env": null,
    "mcp_servers": [],
    "agents": [],
    "app_template": "workflow_orchestrator"
  },
  "visibility": {
    "mode": "private",
    "tenants": []
  },
  "evolution": {
    "enabled": true,
    "strategy_service_url": null,
    "validator_queue": {
      "backend": "redis_stream",
      "redis_url": null,
      "stream_key": "evolution:validate:stream",
      "consumer_group": "evolution-validator-v1",
      "max_retries": 5
    },
    "scope_policy": [
      "tenant_app",
      "tenant_product_line",
      "global_verified"
    ],
    "retrieval": {
      "high_confidence_skip_threshold": 0.82,
      "high_complexity_threshold": 0.7,
      "low_confidence_threshold": 0.55
    },
    "suspicion": {
      "max_age_days": 30,
      "failure_streak_threshold": 2,
      "performance_drop_ratio": 0.2
    }
  }
}
