# FAQ System 専用 .env（apps/faq_system/main.py で自動ロード）
# ルート .env より優先されます。

# --- Platform 主導 LLM 管理 ---
# FAQ app は Provider を直接指定せず、contracts.llm で Platform catalog を参照します。
# 正本設定: apps/platform の LLM Management + .agentflow/llm_gateway.yaml
# FAQ は text / embedding を利用します。Platform 未設定時のみ以下の key を fallback として使います。
# LLM_GATEWAY_CONFIG_PATH=.agentflow/llm_gateway.yaml

# Provider API keys（fallback 用。通常は Platform 画面保存を優先）
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Local inference を使う場合（vLLM / SGLang / TGI は Platform 側で配備）
# 互換 fallback の例:
# LLM_ROLE_REASONING_ALIAS=local_qwen2

# --- AgentFlow 共通設定の FAQ 上書き（必要時のみ） ---
# SUPABASE_URL=
# QDRANT_URL=
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_COLLECTION=faq_knowledge

# --- FAQ アプリ固有 DB（認証/チャット履歴） ---
FAQ_DATABASE_URL=sqlite+aiosqlite:///./faq_system.db
FAQ_DB_AUTO_CREATE=true
FAQ_AUTH_PROVIDER=local_db

# --- auth_service 連携（RBAC / SSO を利用する場合に設定） ---
# AUTH_SERVICE_JWT_SECRET には auth_service 側の JWT_SECRET_KEY と同じ値を設定すること。
# docker-compose.auth-faq.yml で統合起動する場合は、ルート .env の JWT_SECRET_KEY を同じ値で揃えること。
AUTH_SERVICE_URL=http://localhost:8010
AUTH_SERVICE_JWT_SECRET=

# --- 認証モード ---
# ┌──────────────────────┬──────────────────────────────────────────────┐
# │ FAQ_AUTH_MODE         │ 動作                                         │
# ├──────────────────────┼──────────────────────────────────────────────┤
# │ tenant_sso（既定）    │ 同一テナント内 SSO トークン再利用可           │
# │                      │ テナントヘッダー/パス必須                     │
# ├──────────────────────┼──────────────────────────────────────────────┤
# │ enterprise_isolated  │ アプリ隔離、他アプリのトークン拒否             │
# │                      │ テナントヘッダー不要                          │
# └──────────────────────┴──────────────────────────────────────────────┘
# ※ auth_service 到達不可時、FAQ_AUTH_PROVIDER=local_db ならローカル DB にフォールバック
FAQ_AUTH_MODE=tenant_sso
# ローカル開発でテナントヘッダーを省略する場合の既定テナント
FAQ_DEFAULT_TENANT_ID=default

# --- 認証セキュリティ（本番は必須、共有テストは自動生成可） ---
# 自動生成:
# conda run -n agentflow python scripts/bootstrap_test_env.py --env-file .env
JWT_SECRET_KEY=
FAQ_PROXY_AUTH_SHARED_SECRET=
FAQ_PROXY_AUTH_REQUIRE_SIGNATURE=true

# --- FAQ 起動設定 ---
# app_config.json の ports.api が既定。通常は未設定でよい。
# FAQ_HOST=0.0.0.0
# FAQ_PORT=8005

# --- CORS 許可オリジン（カンマ区切り。本番では必ず明示指定） ---
# 例: FAQ_CORS_ORIGINS=https://faq.example.com,https://admin.example.com
FAQ_CORS_ORIGINS=http://localhost:3004

# --- RAG アクセス制御（v3: App 自己管理） ---
# true にすると role/scope 制限が有効（auth_service resolve-scopes 連携）
FAQ_RAG_ACL_ENABLED=false
# confidential 専用 backend を使用
FAQ_CONFIDENTIAL_BACKEND_ENABLED=false
