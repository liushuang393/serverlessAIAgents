# =============================================================================
# Market Trend Monitor 設定例
# このファイルを apps/market_trend_monitor/.env にコピーして使用してください
# =============================================================================

# ポート/HOST は app_config.json から自動取得（定義不要）
# 正本: app_config.json ("api": 8002, "frontend": 3002)

# -----------------------------------------------------------------------------
# データ保存
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./market_trend.db
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Platform 主導 LLM 管理
# -----------------------------------------------------------------------------
# この app は contracts.llm で Platform catalog の text / embedding を参照します。
# Provider / model / API Key の正本は control_plane の LLM Management です。
# 下記 key は Platform 未設定時の fallback 用です。
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# 互換 fallback（通常は不要）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
