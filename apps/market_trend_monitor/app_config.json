{
  "name": "market_trend_monitor",
  "display_name": "市場動向モニター",
  "description": "AIエージェント群による市場トレンド収集・分析・レポート生成システム",
  "business_base": "reasoning",
  "product_line": "framework",
  "surface_profile": "developer",
  "audit_profile": "developer",
  "version": "1.0.0",
  "icon": "📈",
  "ports": {
    "api": 8002,
    "frontend": 3002,
    "db": null,
    "redis": null
  },
  "entry_points": {
    "api_module": "apps.market_trend_monitor.backend.api.main:app",
    "health": "/health"
  },
  "agents": [
    {
      "name": "CollectorAgent",
      "module": "apps.market_trend_monitor.backend.agents.collector_agent",
      "capabilities": [
        "data_collection",
        "web_scraping"
      ],
      "business_base": "integration",
      "pattern": "executor",
      "agent_type": "executor"
    },
    {
      "name": "AnalyzerAgent",
      "module": "apps.market_trend_monitor.backend.agents.analyzer_agent",
      "capabilities": [
        "analysis",
        "trend_detection"
      ],
      "business_base": "reasoning",
      "pattern": "analyzer",
      "agent_type": "reactor"
    },
    {
      "name": "SignalScorerAgent",
      "module": "apps.market_trend_monitor.backend.agents.signal_scorer_agent",
      "capabilities": [
        "signal_scoring",
        "ranking"
      ],
      "business_base": "reasoning",
      "pattern": "analyzer",
      "agent_type": "reactor"
    },
    {
      "name": "EvidenceLedgerAgent",
      "module": "apps.market_trend_monitor.backend.agents.evidence_ledger_agent",
      "capabilities": [
        "evidence_tracking",
        "audit"
      ],
      "business_base": "governance",
      "pattern": "reviewer",
      "agent_type": "reviewer"
    },
    {
      "name": "CompetitorTrackingAgent",
      "module": "apps.market_trend_monitor.backend.agents.competitor_tracking_agent",
      "capabilities": [
        "competitor_analysis",
        "benchmarking"
      ],
      "business_base": "reasoning",
      "pattern": "analyzer",
      "agent_type": "reactor"
    },
    {
      "name": "PredictionReviewAgent",
      "module": "apps.market_trend_monitor.backend.agents.prediction_review_agent",
      "capabilities": [
        "prediction",
        "review"
      ],
      "business_base": "governance",
      "pattern": "reviewer",
      "agent_type": "reviewer"
    },
    {
      "name": "RedteamAgent",
      "module": "apps.market_trend_monitor.backend.agents.redteam_agent",
      "capabilities": [
        "adversarial",
        "validation"
      ],
      "business_base": "governance",
      "pattern": "reviewer",
      "agent_type": "reviewer"
    },
    {
      "name": "ReporterAgent",
      "module": "apps.market_trend_monitor.backend.agents.reporter_agent",
      "capabilities": [
        "reporting",
        "summarization"
      ],
      "business_base": "interaction",
      "pattern": "reporter",
      "agent_type": "reporter"
    },
    {
      "name": "NotifierAgent",
      "module": "apps.market_trend_monitor.backend.agents.notifier_agent",
      "capabilities": [
        "notification",
        "alerting"
      ],
      "business_base": "interaction",
      "pattern": "executor",
      "agent_type": "executor"
    }
  ],
  "services": {
    "workflow": {
      "engine": "MarketTrendWorkflow"
    }
  },
  "dependencies": {
    "database": "sqlite",
    "redis": false,
    "external": []
  },
  "runtime": {
    "urls": {
      "backend": "http://localhost:8002",
      "frontend": "http://localhost:3002",
      "health": "http://localhost:8002/health",
      "database": "sqlite:///./market_trend.db"
    },
    "database": {
      "kind": "sqlite",
      "url": "sqlite:///./market_trend.db",
      "host": null,
      "port": null,
      "name": "market_trend.db",
      "user": null,
      "password": null,
      "password_env": null,
      "note": "ローカルファイルDB"
    },
    "commands": {
      "backend_dev": "python apps/market_trend_monitor/scripts/dev.py",
      "frontend_dev": "cd apps/market_trend_monitor/frontend && npm run dev",
      "publish": "docker compose -f docker-compose.yml up -d --build",
      "start": "docker compose -f docker-compose.yml up -d",
      "stop": "docker compose -f docker-compose.yml down"
    }
  },
  "tags": [
    "market",
    "trend",
    "monitoring",
    "analysis",
    "prediction"
  ],
  "contracts": {
    "auth": {
      "enabled": false,
      "providers": [],
      "allow_anonymous": true,
      "required_scopes": [],
      "session_ttl_minutes": 60
    },
    "rag": {
      "enabled": false,
      "pattern": null,
      "provider": null,
      "collections": [],
      "data_sources": [],
      "chunk_strategy": "recursive",
      "chunk_size": 800,
      "chunk_overlap": 120,
      "retrieval_method": "hybrid",
      "embedding_model": null,
      "rerank_model": null,
      "default_top_k": 5,
      "score_threshold": null,
      "indexing_schedule": null
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true,
      "allowed_sources": [],
      "default_skills": []
    },
    "release": {
      "strategy": "manual",
      "targets": [],
      "environments": [
        "dev"
      ],
      "require_approval": true
    }
  },
  "plugin_bindings": [],
  "blueprint": {
    "engine_pattern": "pipeline",
    "flow_pattern": null,
    "system_prompt": "",
    "llm_provider": null,
    "llm_base_url": null,
    "llm_api_key_env": null,
    "default_model": null,
    "default_skills": [],
    "vector_db_provider": null,
    "vector_db_url": null,
    "vector_db_collection": null,
    "vector_db_api_key_env": null,
    "mcp_servers": [],
    "agents": [],
    "app_template": "intelligence_monitoring"
  },
  "visibility": {
    "mode": "private",
    "tenants": []
  },
  "evolution": {
    "enabled": true,
    "strategy_service_url": null,
    "validator_queue": {
      "backend": "redis_stream",
      "redis_url": null,
      "stream_key": "evolution:validate:stream",
      "consumer_group": "evolution-validator-v1",
      "max_retries": 5
    },
    "scope_policy": [
      "tenant_app",
      "tenant_product_line",
      "global_verified"
    ],
    "retrieval": {
      "high_confidence_skip_threshold": 0.82,
      "high_complexity_threshold": 0.7,
      "low_confidence_threshold": 0.55
    },
    "suspicion": {
      "max_age_days": 30,
      "failure_streak_threshold": 2,
      "performance_drop_ratio": 0.2
    }
  }
}
