# Messaging Hub 設定例
# このファイルを apps/messaging_hub/.env として配置して使用

# =========================================================================
# Platform 主導 LLM 管理
# =========================================================================
# Messaging Hub は contracts.llm で Platform catalog の text / speech 系 model を参照します。
# Provider / model / API Key の正本は control_plane の LLM Management です。
# 下記 key は Platform 未設定時の fallback 用です。
# LLM_GATEWAY_CONFIG_PATH=.agentflow/llm_gateway.yaml

# OpenAI（fallback）
OPENAI_API_KEY=

# Anthropic Claude（fallback）
# ANTHROPIC_API_KEY=

# Google Gemini（fallback）
# GEMINI_API_KEY=

# role alias override（互換 fallback。通常は不要）
# LLM_ROLE_REASONING_ALIAS=reasoning_claude
# LLM_ROLE_CHEAP_ALIAS=cheap_gemini

# =========================================================================
# Messaging Platform（少なくとも1つ設定）
# =========================================================================

# Telegram Bot
# Token 取得: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Slack Bot
# App 作成: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord Bot
# Bot 作成: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# =========================================================================
# App 認証（contracts.auth が有効なため推奨）
# =========================================================================
# 共有テスト時は以下コマンドで自動生成可能:
# conda run -n agentflow python scripts/bootstrap_test_env.py --env-file .env
MESSAGING_HUB_API_KEY_ENV=MESSAGING_HUB_API_KEY
MESSAGING_HUB_API_KEY=


# =========================================================================
# オプション設定
# =========================================================================

# データベース（セッション永続化）
# DATABASE_URL=postgresql://user:pass@localhost:5432/messaging_hub

# Redis（キャッシュ）
# REDIS_URL=redis://localhost:6379

# ログレベル
# LOG_LEVEL=INFO

# サーバー設定
# 既定値（main.py 側）
# HOST=0.0.0.0
# PORT=8000
