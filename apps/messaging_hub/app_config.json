{
  "name": "messaging_hub",
  "display_name": "メッセージングハブ",
  "description": "Telegram・Slack・Discord等マルチプラットフォーム統合AIチャットボット",
  "business_base": "interaction",
  "product_line": "assistant",
  "surface_profile": "business",
  "audit_profile": "business",
  "security_mode": "approval_required",
  "version": "1.0.0",
  "icon": "📨",
  "ports": {
    "api": 8004,
    "frontend": 3001,
    "db": null,
    "redis": null
  },
  "entry_points": {
    "api_module": "apps.messaging_hub.main:app",
    "health": "/health"
  },
  "agents": [
    {
      "name": "PersonalAssistantCoordinator",
      "module": "apps.messaging_hub.coordinator",
      "capabilities": ["coordination", "intent_routing", "summary"],
      "business_base": "interaction",
      "pattern": "coordinator",
      "agent_type": "planner"
    },
    {
      "name": "FileOrganizerAgent",
      "module": "apps.messaging_hub.agents.file_organizer_agent",
      "capabilities": ["file_organization", "categorization"],
      "business_base": "operations",
      "pattern": "specialist",
      "agent_type": "specialist"
    },
    {
      "name": "MeetingAgent",
      "module": "apps.messaging_hub.agents.meeting_agent",
      "capabilities": ["meeting", "calendar", "notes"],
      "business_base": "interaction",
      "pattern": "specialist",
      "agent_type": "specialist"
    }
  ],
  "services": {
    "chatbot": {
      "skill": "ChatBotSkill"
    },
    "websocket": {
      "hub": "WebSocketHub"
    },
    "gateway": {
      "channels": [
        "telegram",
        "slack",
        "discord",
        "teams",
        "whatsapp",
        "signal"
      ]
    }
  },
  "dependencies": {
    "database": null,
    "redis": false,
    "external": ["telegram_api", "slack_api", "discord_api"]
  },
  "runtime": {
    "urls": {
      "backend": "http://localhost:8004",
      "frontend": "http://localhost:3001",
      "health": "http://localhost:8004/health",
      "database": null
    },
    "database": {
      "kind": null,
      "url": null,
      "host": null,
      "port": null,
      "name": null,
      "user": null,
      "password": null,
      "password_env": null,
      "note": null
    },
    "commands": {
      "backend_dev": "python apps/messaging_hub/scripts/dev.py",
      "frontend_dev": "cd apps/messaging_hub/admin_ui && npm run dev",
      "publish": "docker compose -f docker-compose.yml up -d --build",
      "start": "docker compose -f docker-compose.yml up -d",
      "stop": "docker compose -f docker-compose.yml down"
    },
    "cli": {
      "preferred": ["codex", "claude"],
      "codex": {
        "executable": "codex",
        "install_commands": [["npm", "install", "-g", "@openai/codex"]],
        "auth": {
          "status": ["codex", "login", "status"],
          "api_key_env": "OPENAI_API_KEY",
          "api_key_login": ["codex", "login", "--with-api-key"],
          "interactive_login": ["codex", "login"]
        },
        "diagnostic_mode": "read_only",
        "diagnostic_command": [
          "codex",
          "exec",
          "--skip-git-repo-check",
          "--sandbox",
          "read-only"
        ]
      },
      "claude": {
        "executable": "claude",
        "install_commands": [
          ["npm", "install", "-g", "@anthropic-ai/claude-code"]
        ],
        "auth": {
          "status": ["claude", "auth", "status", "--json"],
          "api_key_env": "ANTHROPIC_API_KEY",
          "api_key_login": null,
          "interactive_login": ["claude", "auth", "login"]
        },
        "diagnostic_mode": "plan",
        "diagnostic_command": ["claude", "-p", "--permission-mode", "plan"]
      }
    }
  },
  "tags": [
    "messaging",
    "chatbot",
    "telegram",
    "slack",
    "discord",
    "multi-platform"
  ],
  "contracts": {
    "auth": {
      "enabled": true,
      "providers": ["api_key"],
      "allow_anonymous": false,
      "required_scopes": ["api"],
      "session_ttl_minutes": 60
    },
    "llm": {
      "enabled": true,
      "defaults": {
        "text": {
          "provider": "openai",
          "model_id": "platform_text_default",
          "model_type": "text"
        },
        "speech_to_text": {
          "provider": "openai",
          "model_id": "platform_speech_to_text_default",
          "model_type": "speech_to_text"
        },
        "text_to_speech": {
          "provider": "openai",
          "model_id": "platform_text_to_speech_default",
          "model_type": "text_to_speech"
        }
      },
      "agent_overrides": {},
      "allowed_modalities": [
        "speech_to_text",
        "text",
        "text_to_speech"
      ],
      "extra_model_refs": []
    },
    "rag": {
      "enabled": false,
      "pattern": null,
      "provider": null,
      "collections": [],
      "data_sources": [],
      "chunk_strategy": "recursive",
      "chunk_size": 800,
      "chunk_overlap": 120,
      "retrieval_method": "hybrid",
      "embedding_model": null,
      "rerank_model": null,
      "default_top_k": 5,
      "score_threshold": null,
      "indexing_schedule": null
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true,
      "allowed_sources": [],
      "default_skills": []
    },
    "mcp": {
      "servers": [],
      "lazy_loading": {
        "enabled": true,
        "threshold": 10,
        "auto_load_on_call": true,
        "cache_session": true,
        "default_load_count": 3
      },
      "default_tools": ["list_dir", "read_file", "get_os_info"]
    },
    "release": {
      "strategy": "manual",
      "targets": [],
      "environments": ["dev"],
      "require_approval": true
    }
  },
  "plugin_bindings": [
    {
      "id": "official.channel-adapter-pack",
      "version": "1.0.0",
      "config": {
        "channels": [
          "telegram",
          "slack",
          "discord",
          "teams",
          "whatsapp",
          "signal"
        ]
      }
    },
    {
      "id": "official.assistant-memory-pack",
      "version": "1.0.0",
      "config": {
        "strategy": "managed"
      }
    }
  ],
  "blueprint": {
    "engine_pattern": "coordinator",
    "flow_pattern": null,
    "system_prompt": "",
    "llm_provider": null,
    "llm_base_url": null,
    "llm_api_key_env": null,
    "default_model": null,
    "default_skills": [],
    "vector_db_provider": null,
    "vector_db_url": null,
    "vector_db_collection": null,
    "vector_db_api_key_env": null,
    "mcp_servers": [],
    "agents": [],
    "app_template": "multichannel_assistant"
  },
  "visibility": {
    "mode": "private",
    "tenants": []
  },
  "evolution": {
    "enabled": true,
    "strategy_service_url": null,
    "validator_queue": {
      "backend": "redis_stream",
      "redis_url": null,
      "stream_key": "evolution:validate:stream",
      "consumer_group": "evolution-validator-v1",
      "max_retries": 5
    },
    "scope_policy": ["tenant_app", "tenant_product_line", "global_verified"],
    "retrieval": {
      "high_confidence_skip_threshold": 0.82,
      "high_complexity_threshold": 0.7,
      "low_confidence_threshold": 0.55
    },
    "suspicion": {
      "max_age_days": 30,
      "failure_streak_threshold": 2,
      "performance_drop_ratio": 0.2
    }
  }
}
