{
  "name": "migration_studio",
  "display_name": "Migration Studio",
  "description": "COBOL → Java Spring Boot 移行自動化プラットフォーム",
  "version": "1.0.0",
  "business_base": "operations",
  "product_line": "migration",
  "surface_profile": "business",
  "audit_profile": "business",
  "port": 8010,
  "agents": [
    {
      "name": "AnalyzerAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["cobol_parsing", "legacy_analysis", "risk_detection"],
      "business_base": "operations",
      "pattern": "analyzer"
    },
    {
      "name": "DesignerAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["migration_design", "springboot_architecture", "api_design"],
      "business_base": "operations",
      "pattern": "pipeline_stage"
    },
    {
      "name": "TransformerAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["code_transformation", "java_generation", "rest_api"],
      "business_base": "operations",
      "pattern": "executor"
    },
    {
      "name": "TestGeneratorAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["test_generation", "junit", "golden_master"],
      "business_base": "operations",
      "pattern": "executor"
    },
    {
      "name": "VerifierAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["ast_comparison", "differential_verification"],
      "business_base": "governance",
      "pattern": "reviewer"
    },
    {
      "name": "QualityGateAgent",
      "module": "apps.migration_studio.agents.definitions",
      "capabilities": ["quality_gate", "issue_classification"],
      "business_base": "governance",
      "pattern": "gatekeeper"
    },
    {
      "name": "EvolutionAgent",
      "module": "apps.migration_studio.evolution.manager",
      "capabilities": ["prompt_evolution", "self_improvement", "failure_analysis"],
      "business_base": "operations",
      "pattern": "coordinator"
    }
  ],
  "services": {
    "engine": {
      "pattern": "pipeline",
      "stages": 6,
      "max_evolution_iterations": 3,
      "execution_backend": "cma_cli",
      "execution_backends": ["cma_cli", "legacy_engine"]
    }
  },
  "contracts": {
    "auth": {
      "enabled": false
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true
    }
  },
  "blueprint": {
    "engine_pattern": "pipeline",
    "mcp_servers": []
  },
  "plugin_bindings": []
}
