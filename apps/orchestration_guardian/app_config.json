{
  "name": "orchestration_guardian",
  "display_name": "Orchestration Guardian",
  "description": "全Agentの orchestration 品質を自動スコアリング。\nStreaming / A2A / RAG 契約の準拠状況をリアルタイム監査",
  "business_base": "governance",
  "product_line": "framework",
  "surface_profile": "operator",
  "audit_profile": "developer",
  "version": "1.0.0",
  "icon": "🛡️",
  "ports": {
    "api": 8007,
    "frontend": null,
    "db": null,
    "redis": null
  },
  "entry_points": {
    "api_module": "apps.orchestration_guardian.main:app",
    "health": "/api/health"
  },
  "agents": [
    {
      "name": "OrchestrationGuardianAgent",
      "module": "apps.orchestration_guardian.main",
      "capabilities": [
        "orchestration_validation",
        "protocol_contract_check",
        "readiness_scoring"
      ],
      "business_base": "governance",
      "pattern": "reviewer",
      "agent_type": "reviewer"
    }
  ],
  "services": {
    "governance": {
      "checks": ["orchestration", "protocols", "security_baseline"]
    }
  },
  "dependencies": {
    "database": null,
    "redis": false,
    "external": []
  },
  "runtime": {
    "urls": {
      "backend": "http://localhost:8007",
      "frontend": null,
      "health": "http://localhost:8007/api/health",
      "database": null
    },
    "database": {
      "kind": null,
      "url": null,
      "host": null,
      "port": null,
      "name": null,
      "user": null,
      "password": null,
      "password_env": null,
      "note": null
    },
    "commands": {
      "backend_dev": "python apps/orchestration_guardian/scripts/dev.py",
      "frontend_dev": null,
      "publish": "docker compose -f docker-compose.yml up -d --build",
      "start": "docker compose -f docker-compose.yml up -d",
      "stop": "docker compose -f docker-compose.yml down"
    }
  },
  "tags": ["orchestration", "governance", "protocol", "audit"],
  "contracts": {
    "auth": {
      "enabled": false,
      "providers": [],
      "allow_anonymous": true,
      "required_scopes": [],
      "session_ttl_minutes": 60
    },
    "llm": {
      "enabled": true,
      "defaults": {
        "text": {
          "provider": "openai",
          "model_id": "platform_text_default",
          "model_type": "text"
        }
      },
      "agent_overrides": {},
      "allowed_modalities": ["text"],
      "extra_model_refs": []
    },
    "rag": {
      "enabled": false,
      "pattern": null,
      "provider": null,
      "collections": [],
      "data_sources": [],
      "chunk_strategy": "recursive",
      "chunk_size": 800,
      "chunk_overlap": 120,
      "retrieval_method": "hybrid",
      "embedding_model": null,
      "rerank_model": null,
      "default_top_k": 5,
      "score_threshold": null,
      "indexing_schedule": null
    },
    "skills": {
      "auto_install": false,
      "hot_reload": true,
      "allowed_sources": [],
      "default_skills": []
    },
    "release": {
      "strategy": "manual",
      "targets": [],
      "environments": ["dev"],
      "require_approval": true
    }
  },
  "plugin_bindings": [],
  "blueprint": {
    "engine_pattern": "simple",
    "flow_pattern": null,
    "system_prompt": "",
    "llm_provider": null,
    "llm_base_url": null,
    "llm_api_key_env": null,
    "default_model": null,
    "default_skills": [],
    "vector_db_provider": null,
    "vector_db_url": null,
    "vector_db_collection": null,
    "vector_db_api_key_env": null,
    "mcp_servers": [],
    "agents": [],
    "app_template": "decision_governance"
  },
  "visibility": {
    "mode": "private",
    "tenants": []
  },
  "evolution": {
    "enabled": true,
    "strategy_service_url": null,
    "validator_queue": {
      "backend": "redis_stream",
      "redis_url": null,
      "stream_key": "evolution:validate:stream",
      "consumer_group": "evolution-validator-v1",
      "max_retries": 5
    },
    "scope_policy": ["tenant_app", "tenant_product_line", "global_verified"],
    "retrieval": {
      "high_confidence_skip_threshold": 0.82,
      "high_complexity_threshold": 0.7,
      "low_confidence_threshold": 0.55
    },
    "suspicion": {
      "max_age_days": 30,
      "failure_streak_threshold": 2,
      "performance_drop_ratio": 0.2
    }
  }
}
