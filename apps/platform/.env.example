# =============================================================================
# Platform 設定例
# このファイルを apps/platform/.env にコピーして使用してください
# =============================================================================

# -----------------------------------------------------------------------------
# Platform backend
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
PLATFORM_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Platform LLM 管理 DB
# -----------------------------------------------------------------------------
# 既定は SQLite。PostgreSQL を使う場合は PLATFORM_DATABASE_URL を上書きしてください。
PLATFORM_DATABASE_URL=sqlite+aiosqlite:///./apps/platform/data/platform.db
PLATFORM_DB_AUTO_CREATE=true
PLATFORM_DB_ECHO=false

# Provider secret 暗号化キー
# 本番では必ず強いランダム値または十分長いパスフレーズを設定してください。
PLATFORM_SECRET_MASTER_KEY=

# runtime secret cache
PLATFORM_RUNTIME_CACHE_DB=./apps/platform/data/platform_runtime_cache.db

# -----------------------------------------------------------------------------
# Provider key fallback
# -----------------------------------------------------------------------------
# 通常は Platform 画面で暗号化保存してください。
# ここに置く値は Platform 未設定時の fallback です。
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# 招待メール（必要時のみ）
# -----------------------------------------------------------------------------
PLATFORM_INVITE_EMAIL_TRANSPORT=memory
PLATFORM_INVITE_ENABLE_OUTBOX_ENDPOINT=false
# PLATFORM_INVITE_SMTP_HOST=
# PLATFORM_INVITE_SMTP_PORT=587
# PLATFORM_INVITE_SMTP_STARTTLS=true
# PLATFORM_INVITE_SMTP_USERNAME=
# PLATFORM_INVITE_SMTP_PASSWORD=
# PLATFORM_INVITE_FROM_EMAIL=
# PLATFORM_INVITE_LOGIN_BASE_URL=http://localhost:3000/login
# PLATFORM_INVITE_SUPPORT_CONTACT=support@example.com
# PLATFORM_INVITE_TOKEN_PEPPER=

# -----------------------------------------------------------------------------
# CORS / 運用
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
